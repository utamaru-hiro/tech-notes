{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "paths": {
      "@tech-notes/content": ["./packages/content/types.ts"],
      "@tech-notes/content/crypto": ["./packages/content/crypto/data.ts"],
      "@tech-notes/content/language/*": ["./packages/content/language/*/data.ts"]
    }
  },
  "include": [
    "packages/**/*.ts"
  ]
}
